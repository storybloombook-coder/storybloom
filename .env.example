# Storybloom — environment variables template
#
# HOW TO USE (on the other PC, during the session):
# 1. Copy this file to a new file named exactly ".env"
#      cp .env.example .env
# 2. Paste your real Gemini API key into .env (the AIza... string).
# 3. NEVER commit .env — it is already in .gitignore.
# 4. This .env.example file is safe to commit (it has no real key).
#
# In Expo, vars must be prefixed EXPO_PUBLIC_ to be readable in app code.
# NOTE: EXPO_PUBLIC_ vars are embedded in the app bundle and are NOT truly
# secret. For a local dev / prototype build that is acceptable. If this ever
# ships to real users, move the Gemini call behind a small proxy so the key
# is not shipped inside the app. (This is a documented v2 concern.)

# Your FREE Gemini API key from Google AI Studio (starts with AIza...)
EXPO_PUBLIC_GEMINI_API_KEY=AIza_PASTE_YOUR_FREE_KEY_HERE

# Which free Gemini model to use for vision/OCR/analysis.
# Use a current FREE-tier Flash model (NOT a Pro model — Pro is paid).
# Verify the exact current model name in Google AI Studio when you set up.
EXPO_PUBLIC_GEMINI_MODEL=gemini-flash-latest
